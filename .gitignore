# deps
/node_modules
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next
/.next/
/out/
next-env.d.ts

# build
/build
/dist

# mobile (Expo / React Native) — generated native projects + caches.
# The iOS/Android projects are regenerated from app.json via `expo prebuild`
# (Continuous Native Generation), so we don't track them.
apps/*/.expo/
apps/*/ios/
apps/*/android/
apps/*/dist/
apps/*/.expo-shared/
*.keystore
*.jks

# env
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# misc
.DS_Store
*.pem
.vercel
.idea
.vscode/*
!.vscode/extensions.json
*.tsbuildinfo

# Claude Code local — ignore per-machine settings but ship project skills
.claude/*
!.claude/skills/
.env*

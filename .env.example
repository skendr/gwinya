# --- AI -------------------------------------------------------------------
# Anthropic Claude. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
# Optional model overrides — defaults in lib/ai/models.ts
# ANTHROPIC_MODEL=claude-opus-4-7
# ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001

# OpenAI — powers the voice meal companion (Realtime API over WebRTC).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Optional Realtime model override — default in app/api/realtime/session/route.ts
# OPENAI_REALTIME_MODEL=gpt-realtime

# --- Supabase (auto-wired by Vercel Marketplace integration) --------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Postgres (auto-wired by Vercel Marketplace integration) --------------
# Pooled — use for serverless / edge
POSTGRES_URL=
# Direct connection — required for drizzle-kit migrations
POSTGRES_URL_NON_POOLING=

# --- Email ---------------------------------------------------------------
# https://resend.com — start with the onboarding sender, then verify a domain
RESEND_API_KEY=re_...
# Optional: override the From address once you verify a domain
# RESEND_FROM="Gwinya <hello@gwinya.app>"

# --- Site ----------------------------------------------------------------
# Used to build absolute URLs for magic-link callbacks. Vercel sets VERCEL_URL
# automatically; this is an override for custom domains.
# NEXT_PUBLIC_SITE_URL=https://gwinya.app
